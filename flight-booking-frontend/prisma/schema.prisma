datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  name     String?
  password String
  role     Role   @default(BUYER)
}

enum Role {
  ADMIN
  BUYER
}


model Flight {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  airline     String
  from        String
  to          String
  departure   DateTime
  arrival     DateTime
  price       Int
  seats       Int
  createdAt   DateTime @default(now())
}





